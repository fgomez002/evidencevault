# Copy to .env and fill in. These are PUBLIC client keys (safe for the app bundle).
# The Supabase anon key is protected by Row Level Security — it is NOT a secret in the
# way a service_role key is. Never put the service_role key in the app.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLISHABLE-KEY

# RevenueCat public SDK keys (safe to ship). From RevenueCat dashboard →
# Project settings → API keys → "Public app-specific" keys, one per platform.
# Without these, the paywall falls back to the local demo toggle.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_XXXXXXXXXXXXXXXX
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_XXXXXXXXXXXXXXXX
