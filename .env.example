# Supabase Configuration
# Get these from your Supabase dashboard: https://supabase.com/dashboard
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxx

# RevenueCat In-App Purchases
# Set these after configuring products in App Store Connect and Google Play Console
# Get values from: https://dashboard.revenuecat.com
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxx

# Claude API Key (for AI assistant)
# DO NOT add this to .env — set it as a Supabase Edge Function secret instead:
# supabase secrets set ANTHROPIC_API_KEY=sk-ant-... --project-ref <ref>
